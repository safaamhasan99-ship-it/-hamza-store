<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>إدارة المنتجات | مجمع حمزه الشطري</title>

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;800&display=swap" rel="stylesheet">

<link rel="stylesheet" href="style.css">

</head>

<body>

<header class="header">

<div class="top-header">

<div class="brand">

<h1>مجمع حمزه الشطري</h1>

<p>لوحة إدارة المنتجات</p>

</div>

</div>

</header>

<section class="products">

<h2 class="title">
➕ إضافة منتج جديد
</h2>

<div class="about-box">

<input
id="productName"
type="text"
placeholder="اسم المنتج">

<br><br>

<input
id="productPrice"
type="number"
placeholder="سعر المنتج">

<br><br>

<input
id="productImage"
type="text"
placeholder="رابط صورة المنتج">

<br><br>

<textarea
id="productDescription"
placeholder="وصف المنتج"
rows="4"
style="width:100%;padding:12px;border:1px solid #ddd;border-radius:10px;resize:vertical;"></textarea>

<br><br>

<select id="productCategory">

<option value="men">👔 القسم الرجالي</option>

<option value="women">👗 القسم النسائي</option>

<option value="boys">🧒 القسم الولادي</option>

<option value="girls">👧 القسم البناتي</option>

<option value="pants">👖 البنطرونات</option>

<option value="underwear">🩳 الداخليات الرجالي</option>

<option value="socks">🧦 الجوارب</option>

</select>

<br><br>

<button
class="cart-btn"
onclick="addProduct()">

💾 حفظ المنتج

</button>

</div>

<h2 class="title">
📦 المنتجات المضافة
</h2>

<div style="text-align:center;margin-bottom:20px;">

<button
class="cart-btn"
onclick="refreshProducts()">

🔄 تحديث المنتجات

</button>

</div>

<div
id="productsList"
class="products-grid">

</div>

</section>

<script type="module" src="admin-products.js"></script>

</body>

</html>
