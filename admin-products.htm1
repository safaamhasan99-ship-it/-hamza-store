<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>إدارة المنتجات | مجمع حمزه الشطري</title>

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;800&display=swap" rel="stylesheet">

<link rel="stylesheet" href="style.css">

<style>

.form-box{
max-width:700px;
margin:20px auto;
background:#fff;
padding:25px;
border-radius:18px;
box-shadow:0 10px 25px rgba(0,0,0,.08);
}

.form-box input,
.form-box textarea,
.form-box select{
width:100%;
padding:14px;
margin-bottom:15px;
border:1px solid #ddd;
border-radius:10px;
font-family:'Cairo',sans-serif;
font-size:15px;
}

.form-box input[type=file]{
padding:10px;
}

.form-box button{
width:100%;
padding:15px;
background:#c79b3b;
color:#fff;
border:none;
border-radius:10px;
font-size:18px;
font-weight:bold;
cursor:pointer;
}

.form-box button:hover{
background:#b3872e;
}

</style>

</head>

<body>

<header class="header">

<div class="top-header">

<div class="brand">

<h1>مجمع حمزه الشطري</h1>

<p>لوحة إدارة المنتجات</p>

</div>

</div>

</header>

<section class="products">

<h2 class="title">
➕ إضافة منتج جديد
</h2>

<div class="form-box">

<input
id="productName"
type="text"
placeholder="اسم المنتج">

<input
id="productPrice"
type="number"
placeholder="السعر">

<textarea
id="productDescription"
rows="4"
placeholder="وصف المنتج"></textarea>

<select id="productCategory">

<option value="men">👔 القسم الرجالي</option>

<option value="women">👗 القسم النسائي</option>

<option value="boys">🧒 القسم الولادي</option>

<option value="girls">👧 القسم البناتي</option>

<option value="pants">👖 البنطرونات</option>

<option value="underwear">🩳 الداخليات</option>

<option value="socks">🧦 الجوارب</option>

</select>

<input
type="file"
id="imageFile"
accept="image/*">

<button
id="saveBtn"
type="button"
onclick="saveProduct()">

💾 حفظ المنتج

</button>

</div>

<h2 class="title">

📦 المنتجات المضافة

</h2>

<div style="text-align:center;margin-bottom:20px;">

<button
class="cart-btn"
onclick="refreshProducts()">

🔄 تحديث المنتجات

</button>

</div>

<div
id="productsList"
class="products-grid">
</div>

</section>

<footer style="text-align:center;padding:25px;color:#777;">

مجمع حمزه الشطري © 2026

</footer>

<script type="module" src="admin-products.js"></script>

</body>

</html>
