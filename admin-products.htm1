<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>إدارة المنتجات | مجمع حمزه الشطري</title>

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;800&display=swap" rel="stylesheet">

<link rel="stylesheet" href="style.css">

</head>


<body>


<header class="header">

<div class="top-header">

<div class="brand">

<h1>
مجمع حمزه الشطري
</h1>

<p>
إضافة المنتجات
</p>

</div>

</div>

</header>



<section class="products">


<h2 class="title">
➕ إضافة منتج جديد
</h2>



<div class="about-box">


<input id="productName"
placeholder="اسم المنتج">


<br><br>


<input id="productPrice"
type="number"
placeholder="السعر">


<br><br>


<input id="productImage"
placeholder="رابط صورة المنتج">


<br><br>


<select id="productCategory">


<option value="men">
رجالي
</option>


<option value="women">
نسائي
</option>


<option value="boys">
ولادي
</option>


<option value="girls">
بناتي
</option>


<option value="socks">
جوارب
</option>


</select>


<br><br>



<button onclick="addProduct()">

حفظ المنتج

</button>



</div>



<h2 class="title">
📦 المنتجات المضافة
</h2>



<div id="productsList" class="products-grid">


</div>



</section>




<script type="module" src="admin-products.js"></script>


</body>

</html>
