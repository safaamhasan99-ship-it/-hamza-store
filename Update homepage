<title>مجمع حمزه الشطري</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{
font-family:Tahoma,Arial,sans-serif;
background:#111;
color:#fff;
}

header{
background:#000;
padding:15px;
display:flex;
justify-content:space-between;
align-items:center;
position:sticky;
top:0;
}

.logo{
font-size:26px;
font-weight:bold;
color:#d4af37;
}

nav a{
color:#fff;
text-decoration:none;
margin:0 10px;
font-size:15px;
}

.hero{
background:linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.6)),url("https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=1200");
